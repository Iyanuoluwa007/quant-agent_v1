# ===================================================================
# AI Trading Agent - Environment Variables
# Copy this to .env and fill in your values
# ===================================================================

# -- Broker Selection ---------------------------------------------------
# "alpaca" = Alpaca (free paper trading)
# "trading212" = Trading212 (real capital)
BROKER=alpaca

# -- Alpaca API (Paper Trading) ----------------------------------------
# Sign up: https://app.alpaca.markets/signup
# Dashboard -> Paper Trading -> API Keys
ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_ENV=paper

# -- Trading212 API ----------------------------------------------------
# Settings -> API (Beta)
T212_API_KEY=
T212_API_SECRET=
T212_ENV=demo

# -- Claude API Key ----------------------------------------------------
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# -- Optional Overrides ------------------------------------------------
# CLAUDE_MODEL=claude-sonnet-4-5-20250929
# LOG_LEVEL=DEBUG
# ANALYSIS_INTERVAL=30
